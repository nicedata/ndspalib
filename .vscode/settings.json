{
    "python.languageServer": "Default",
    "js/ts.implicitProjectConfig.checkJs": true,
    "js/ts.validate.enabled": false,
    "files.exclude": {
        "releases": true,
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/__pycache__": true,
        "**/venv**": true,
        "**/docs**": true,
        "**/ndspalib.js": true,
        "**/release": true
    },
    "emeraldwalk.runonsave": {
        "message": "*** All Start ***",
        "messageAfter": "*** All Complete ***",
        "commands": [
            {
                // Run whenever any file is saved
                "match": ".js",
                // "cmd": "esbuild src/server/static/js/main.js --bundle --minify --outfile=release/ndspalib.js"
                "cmd": "esbuild src/server/static/js/main.js --bundle --outfile=release/ndspalib.js"
            }
        ]
    },
    "editor.fontFamily": "'JetBrains Mono', monospace",
    "editor.fontLigatures": true,
    "editor.lineHeight": 20,
    "editor.fontSize": 14,
    "editor.tabSize": 4,
    "terminal.integrated.fontFamily": "'JetBrains Mono', monospace",
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.lineHeight": 1.3
}
